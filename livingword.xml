<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_livingword</name>
    <author>CWM Team</author>
    <authorEmail>info@christianwebministries.org</authorEmail>
    <authorUrl>www.christianwebministries.org</authorUrl>
    <copyright>(C) 2026 CWM Team All rights reserved.</copyright>
    <version>5.5.0</version>
    <creationDate>2026-05-17</creationDate>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <description>COM_LIVINGWORD_XML_DESCRIPTION</description>
    <namespace path="src">CWM\Component\Livingword</namespace>

    <compatibility>
        <cms>
            <targetplatform name="joomla" version="5[.0-9]" />
            <targetplatform name="joomla" version="6[.0-9]" />
        </cms>
        <php minimum="8.3.0" />
    </compatibility>

    <scriptfile>script.php</scriptfile>

    <languages folder="site/language">
        <language tag="cs-CZ">cs-CZ/com_livingword.ini</language>
        <language tag="de-DE">de-DE/com_livingword.ini</language>
        <language tag="en-GB">en-GB/com_livingword.ini</language>
        <language tag="es-ES">es-ES/com_livingword.ini</language>
        <language tag="fr-FR">fr-FR/com_livingword.ini</language>
        <language tag="hu-HU">hu-HU/com_livingword.ini</language>
        <language tag="it-IT">it-IT/com_livingword.ini</language>
        <language tag="ja-JP">ja-JP/com_livingword.ini</language>
        <language tag="ko-KR">ko-KR/com_livingword.ini</language>
        <language tag="nl-NL">nl-NL/com_livingword.ini</language>
        <language tag="no-NO">no-NO/com_livingword.ini</language>
        <language tag="pt-BR">pt-BR/com_livingword.ini</language>
        <language tag="ru-RU">ru-RU/com_livingword.ini</language>
        <language tag="zh-CN">zh-CN/com_livingword.ini</language>
    </languages>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <media destination="com_livingword" folder="media/com_livingword">
        <folder>css</folder>
        <folder>js</folder>
    </media>

    <files folder="site">
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <administration>
        <menu img="class:component">COM_LIVINGWORD</menu>
        <submenu>
            <menu link="option=com_livingword&amp;view=cwmcpanel"
                  view="cwmcpanel"
                  alt="LivingWord/ControlPanel">
                COM_LIVINGWORD_CPANEL
            </menu>
            <menu link="option=com_livingword&amp;view=cwmplans"
                  view="cwmplans"
                  alt="LivingWord/Plans">
                COM_LIVINGWORD_MANAGE_PLANS
            </menu>
            <menu link="option=com_livingword&amp;view=cwmlinks"
                  view="cwmlinks"
                  alt="LivingWord/Links">
                COM_LIVINGWORD_MANAGE_LINKS
            </menu>
            <menu link="option=com_livingword&amp;view=cwmgroups"
                  view="cwmgroups"
                  alt="LivingWord/Groups">
                COM_LIVINGWORD_MANAGE_GROUPS
            </menu>
            <menu link="option=com_livingword&amp;view=cwmtools"
                  view="cwmtools"
                  alt="LivingWord/Tools">
                COM_LIVINGWORD_MANAGE_TOOLS
            </menu>
            <menu link="option=com_livingword&amp;view=cwmusers"
                  view="cwmusers"
                  alt="LivingWord/Users">
                COM_LIVINGWORD_MANAGE_SUBSCRIBERS
            </menu>
        </submenu>

        <files folder="admin">
            <filename>access.xml</filename>
            <filename>config.xml</filename>
            <folder>forms</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>

        <languages folder="admin/language">
            <language tag="cs-CZ">cs-CZ/com_livingword.ini</language>
            <language tag="cs-CZ">cs-CZ/com_livingword.sys.ini</language>
            <language tag="de-DE">de-DE/com_livingword.ini</language>
            <language tag="de-DE">de-DE/com_livingword.sys.ini</language>
            <language tag="en-GB">en-GB/com_livingword.ini</language>
            <language tag="en-GB">en-GB/com_livingword.sys.ini</language>
            <language tag="es-ES">es-ES/com_livingword.ini</language>
            <language tag="es-ES">es-ES/com_livingword.sys.ini</language>
            <language tag="fr-FR">fr-FR/com_livingword.ini</language>
            <language tag="fr-FR">fr-FR/com_livingword.sys.ini</language>
            <language tag="hu-HU">hu-HU/com_livingword.ini</language>
            <language tag="hu-HU">hu-HU/com_livingword.sys.ini</language>
            <language tag="it-IT">it-IT/com_livingword.ini</language>
            <language tag="it-IT">it-IT/com_livingword.sys.ini</language>
            <language tag="ja-JP">ja-JP/com_livingword.ini</language>
            <language tag="ja-JP">ja-JP/com_livingword.sys.ini</language>
            <language tag="ko-KR">ko-KR/com_livingword.ini</language>
            <language tag="ko-KR">ko-KR/com_livingword.sys.ini</language>
            <language tag="nl-NL">nl-NL/com_livingword.ini</language>
            <language tag="nl-NL">nl-NL/com_livingword.sys.ini</language>
            <language tag="no-NO">no-NO/com_livingword.ini</language>
            <language tag="no-NO">no-NO/com_livingword.sys.ini</language>
            <language tag="pt-BR">pt-BR/com_livingword.ini</language>
            <language tag="pt-BR">pt-BR/com_livingword.sys.ini</language>
            <language tag="ru-RU">ru-RU/com_livingword.ini</language>
            <language tag="ru-RU">ru-RU/com_livingword.sys.ini</language>
            <language tag="zh-CN">zh-CN/com_livingword.ini</language>
            <language tag="zh-CN">zh-CN/com_livingword.sys.ini</language>
        </languages>
    </administration>
</extension>
