<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="CWM\Component\Livingword\Administrator\Field">
    <fieldset>
        <field
            name="id"
            type="hidden"
            default="0"
        />
        <field
            name="name"
            type="text"
            label="COM_LIVINGWORD_GROUP_NAME"
            description="COM_LIVINGWORD_GROUP_NAME_DESC"
            required="true"
            size="50"
            maxlength="200"
        />
        <field
            name="description"
            type="editor"
            label="COM_LIVINGWORD_GROUP_DESCRIPTION"
            description="COM_LIVINGWORD_GROUP_DESCRIPTION_DESC"
            filter="safehtml"
            buttons="true"
        />
        <field
            name="plan_id"
            type="PlanId"
            label="COM_LIVINGWORD_GROUP_PLAN"
            description="COM_LIVINGWORD_GROUP_PLAN_DESC"
            required="true"
        >
            <option value="">COM_LIVINGWORD_SELECT_PLAN</option>
        </field>
        <field
            name="start_date"
            type="calendar"
            label="COM_LIVINGWORD_GROUP_START_DATE"
            description="COM_LIVINGWORD_GROUP_START_DATE_DESC"
            format="%Y-%m-%d"
        />
        <field
            name="invite_token"
            type="text"
            label="COM_LIVINGWORD_GROUP_INVITE_TOKEN"
            description="COM_LIVINGWORD_GROUP_INVITE_TOKEN_DESC"
            hint="COM_LIVINGWORD_GROUP_INVITE_TOKEN_HINT"
            readonly="true"
            size="64"
        />
        <field
            name="join_mode"
            type="list"
            label="COM_LIVINGWORD_GROUP_JOIN_MODE"
            description="COM_LIVINGWORD_GROUP_JOIN_MODE_DESC"
            default="open"
            validate="options"
        >
            <option value="open">COM_LIVINGWORD_GROUP_JOIN_OPEN</option>
            <option value="request">COM_LIVINGWORD_GROUP_JOIN_REQUEST</option>
            <option value="private">COM_LIVINGWORD_GROUP_JOIN_PRIVATE</option>
        </field>
        <field
            name="published"
            type="list"
            label="JSTATUS"
            class="form-select-color-state"
            default="1"
            validate="options"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field
            name="ordering"
            type="number"
            label="JFIELD_ORDERING_LABEL"
        />
    </fieldset>
</form>
