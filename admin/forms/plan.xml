<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset addfieldprefix="CWM\Component\Livingword\Administrator\Field">
        <field
            name="id"
            type="text"
            label="JGLOBAL_FIELD_ID_LABEL"
            class="readonly"
            readonly="true"
            size="10"
            default="0"
        />
        <field
            name="name"
            type="text"
            label="COM_LIVINGWORD_PLAN_NAME"
            description="COM_LIVINGWORD_PLAN_NAME_DESC"
            required="true"
            size="50"
            maxlength="50"
        />
        <field
            name="description"
            type="text"
            label="COM_LIVINGWORD_PLAN_DESCRIPTION"
            description="COM_LIVINGWORD_PLAN_DESCRIPTION_DESC"
            required="true"
            size="100"
        />
        <field
            name="message"
            type="editor"
            label="COM_LIVINGWORD_PLAN_MESSAGE"
            description="COM_LIVINGWORD_PLAN_MESSAGE_DESC"
            filter="safehtml"
            buttons="true"
        />
        <field
            name="audio"
            type="list"
            label="COM_LIVINGWORD_PLAN_AUDIO"
            description="COM_LIVINGWORD_PLAN_AUDIO_DESC"
            default="0"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field
            name="newtest"
            type="list"
            label="COM_LIVINGWORD_PLAN_TESTAMENT"
            description="COM_LIVINGWORD_PLAN_TESTAMENT_DESC"
            default="0"
        >
            <option value="0">COM_LIVINGWORD_PLAN_TESTAMENT_FULL</option>
            <option value="1">COM_LIVINGWORD_PLAN_TESTAMENT_NT</option>
            <option value="2">COM_LIVINGWORD_PLAN_TESTAMENT_OT</option>
        </field>
        <field
            name="published"
            type="list"
            label="JSTATUS"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field
            name="ordering"
            type="text"
            label="JFIELD_ORDERING_LABEL"
            size="6"
        />
    </fieldset>
</form>
