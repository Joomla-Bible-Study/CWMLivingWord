<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset>
        <field
            name="id"
            type="hidden"
            default="0"
        />
        <field
            name="alias"
            type="text"
            label="COM_LIVINGWORD_PLAN_ALIAS"
            description="COM_LIVINGWORD_PLAN_ALIAS_DESC"
            required="true"
            size="50"
            maxlength="50"
        />
        <field
            name="title"
            type="text"
            label="COM_LIVINGWORD_PLAN_TITLE"
            description="COM_LIVINGWORD_PLAN_TITLE_DESC"
            required="true"
            size="100"
            maxlength="200"
        />
        <field
            name="description"
            type="editor"
            label="COM_LIVINGWORD_PLAN_DESCRIPTION"
            description="COM_LIVINGWORD_PLAN_DESCRIPTION_DESC"
            filter="safehtml"
            buttons="true"
        />
        <field
            name="message"
            type="editor"
            label="COM_LIVINGWORD_PLAN_MESSAGE"
            description="COM_LIVINGWORD_PLAN_MESSAGE_DESC"
            filter="safehtml"
            buttons="true"
        />
        <field
            name="audio"
            type="radio"
            label="COM_LIVINGWORD_PLAN_AUDIO"
            description="COM_LIVINGWORD_PLAN_AUDIO_DESC"
            layout="joomla.form.field.radio.switcher"
            default="0"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
            name="audio_version"
            type="list"
            label="COM_LIVINGWORD_PLAN_AUDIO_VERSION"
            description="COM_LIVINGWORD_PLAN_AUDIO_VERSION_DESC"
            showon="audio:1"
        >
            <option value="">COM_LIVINGWORD_PLAN_AUDIO_VERSION_DEFAULT</option>
            <option value="kjv">KJV</option>
            <option value="nkjv">NKJV</option>
            <option value="niv">NIV</option>
            <option value="esv">ESV</option>
            <option value="nlt">NLT</option>
            <option value="nasb">NASB</option>
            <option value="amp">AMP</option>
            <option value="csb">CSB</option>
            <option value="web">WEB</option>
            <option value="msg">MSG</option>
        </field>
        <field
            name="testament"
            type="list"
            label="COM_LIVINGWORD_PLAN_TESTAMENT"
            description="COM_LIVINGWORD_PLAN_TESTAMENT_DESC"
            default="0"
            validate="options"
        >
            <option value="0">COM_LIVINGWORD_PLAN_TESTAMENT_FULL</option>
            <option value="1">COM_LIVINGWORD_PLAN_TESTAMENT_NT</option>
            <option value="2">COM_LIVINGWORD_PLAN_TESTAMENT_OT</option>
        </field>
        <field
            name="duration_type"
            type="list"
            label="COM_LIVINGWORD_PLAN_DURATION_TYPE"
            description="COM_LIVINGWORD_PLAN_DURATION_TYPE_DESC"
            default="annual"
            validate="options"
        >
            <option value="annual">COM_LIVINGWORD_PLAN_DURATION_ANNUAL</option>
            <option value="fixed">COM_LIVINGWORD_PLAN_DURATION_FIXED</option>
            <option value="self_paced">COM_LIVINGWORD_PLAN_DURATION_SELF_PACED</option>
        </field>
        <field
            name="total_days"
            type="number"
            label="COM_LIVINGWORD_PLAN_TOTAL_DAYS"
            description="COM_LIVINGWORD_PLAN_TOTAL_DAYS_DESC"
            min="1"
            max="400"
            showon="duration_type!:annual"
        />
        <field
            name="published"
            type="list"
            label="JSTATUS"
            class="form-select-color-state"
            default="1"
            validate="options"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field
            name="ordering"
            type="hidden"
            default="0"
        />
    </fieldset>
    <fieldset name="devotional_modal">
        <field
            name="devotional_editor_content"
            type="editor"
            label="COM_LIVINGWORD_READING_DEVOTIONAL"
            hiddenLabel="true"
            filter="safehtml"
            buttons="true"
            height="400"
        />
    </fieldset>
    <fieldset name="readings_fieldset" label="COM_LIVINGWORD_PLAN_READINGS">
        <field
            name="readings"
            type="subform"
            label="COM_LIVINGWORD_PLAN_READINGS"
            hiddenLabel="true"
            formsource="reading_row"
            multiple="true"
            min="0"
            max="400"
            layout="joomla.form.field.subform.repeatable-table"
            buttons="add,remove,move"
            groupByFieldset="false"
        />
    </fieldset>
</form>
