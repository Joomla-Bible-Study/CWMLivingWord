<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details">
        <field
            name="id"
            type="hidden"
            default="0"
        />
        <field
            name="name"
            type="text"
            label="COM_LIVINGWORD_TOOL_NAME"
            description="COM_LIVINGWORD_TOOL_NAME_DESC"
            required="true"
            size="60"
            maxlength="200"
        />
        <field
            name="description"
            type="editor"
            label="COM_LIVINGWORD_TOOL_DESCRIPTION"
            description="COM_LIVINGWORD_TOOL_DESCRIPTION_DESC"
            filter="safehtml"
            buttons="true"
            height="200"
        />
        <field
            name="url"
            type="url"
            label="COM_LIVINGWORD_TOOL_URL"
            description="COM_LIVINGWORD_TOOL_URL_DESC"
            required="true"
            size="60"
            maxlength="200"
        />
        <field
            name="icon"
            type="list"
            label="COM_LIVINGWORD_TOOL_ICON"
            description="COM_LIVINGWORD_TOOL_ICON_DESC"
        >
            <option value="">- None -</option>
            <option value="icon-book">Book</option>
            <option value="icon-bookmark">Bookmark</option>
            <option value="icon-file-alt">Document</option>
            <option value="icon-search">Search</option>
            <option value="icon-location">Location</option>
            <option value="icon-globe">Globe</option>
            <option value="icon-link">Link</option>
            <option value="icon-comments">Comments</option>
            <option value="icon-quote-left">Quote</option>
            <option value="icon-pencil-alt">Pencil</option>
            <option value="icon-users">Users</option>
            <option value="icon-graduation-cap">Graduation Cap</option>
            <option value="icon-lightbulb">Lightbulb</option>
            <option value="icon-play">Play</option>
            <option value="icon-headphones">Headphones</option>
            <option value="icon-video">Video</option>
            <option value="icon-calendar">Calendar</option>
            <option value="icon-star">Star</option>
            <option value="icon-heart">Heart</option>
            <option value="icon-info-circle">Info</option>
            <option value="icon-question-circle">Question</option>
        </field>
        <field
            name="color"
            type="list"
            label="COM_LIVINGWORD_TOOL_COLOR"
            description="COM_LIVINGWORD_TOOL_COLOR_DESC"
        >
            <option value="">- Default -</option>
            <option value="text-primary">Blue</option>
            <option value="text-success">Green</option>
            <option value="text-danger">Red</option>
            <option value="text-warning">Yellow</option>
            <option value="text-info">Cyan</option>
            <option value="text-secondary">Grey</option>
            <option value="text-dark">Dark</option>
        </field>
        <field
            name="published"
            type="list"
            label="JSTATUS"
            class="form-select-color-state"
            default="1"
            validate="options"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field
            name="catid"
            type="categoryedit"
            label="JCATEGORY"
            extension="com_livingword.tool"
            addfieldprefix="Joomla\Component\Categories\Administrator\Field"
            default=""
        />
        <field
            name="ordering"
            type="hidden"
            default="0"
        />
    </fieldset>
</form>
