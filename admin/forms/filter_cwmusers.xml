<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="COM_LIVINGWORD_FILTER_SEARCH_LABEL"
            description="COM_LIVINGWORD_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER"
        />
        <field
            name="plan_id"
            type="sql"
            label="COM_LIVINGWORD_USER_PLAN"
            onchange="this.form.submit();"
            query="SELECT id AS value, title AS text FROM #__livingword_plans WHERE published = 1 ORDER BY ordering"
        >
            <option value="">COM_LIVINGWORD_FILTER_ALL_PLANS</option>
        </field>
        <field
            name="email"
            type="list"
            label="COM_LIVINGWORD_USER_EMAIL_SUB"
            onchange="this.form.submit();"
        >
            <option value="">COM_LIVINGWORD_FILTER_ALL</option>
            <option value="1">COM_LIVINGWORD_FILTER_SUBSCRIBED</option>
            <option value="0">COM_LIVINGWORD_FILTER_UNSUBSCRIBED</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="u.name ASC"
            onchange="this.form.submit();"
        >
            <option value="u.name ASC">COM_LIVINGWORD_USER_NAME_ASC</option>
            <option value="u.name DESC">COM_LIVINGWORD_USER_NAME_DESC</option>
            <option value="a.streak_current DESC">COM_LIVINGWORD_SORT_STREAK_DESC</option>
            <option value="a.streak_current ASC">COM_LIVINGWORD_SORT_STREAK_ASC</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
        </field>
        <field
            name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();"
        />
    </fields>
</form>
