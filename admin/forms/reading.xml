<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="CWM\Component\Livingword\Administrator\Field">
    <fieldset>
        <field
            name="id"
            type="hidden"
            default="0"
        />
        <field
            name="plan"
            type="Plan"
            label="COM_LIVINGWORD_PLAN"
            description="COM_LIVINGWORD_READING_PLAN_DESC"
            required="true"
        >
            <option value="">COM_LIVINGWORD_SELECT_PLAN</option>
        </field>
        <field
            name="reading"
            type="text"
            label="COM_LIVINGWORD_READING"
            description="COM_LIVINGWORD_READING_DESC"
            hint="COM_LIVINGWORD_READING_HINT"
            required="true"
            size="80"
            maxlength="255"
        />
        <field
            name="audio"
            type="url"
            label="COM_LIVINGWORD_READING_AUDIO"
            description="COM_LIVINGWORD_READING_AUDIO_OVERRIDE_DESC"
            hint="COM_LIVINGWORD_READING_AUDIO_HINT"
            size="80"
            maxlength="255"
        />
        <field
            name="descrip"
            type="textarea"
            label="COM_LIVINGWORD_READING_DESCRIPTION"
            description="COM_LIVINGWORD_READING_DESCRIPTION_DESC"
            rows="3"
            cols="60"
        />
        <field
            name="ordering"
            type="number"
            label="JFIELD_ORDERING_LABEL"
        />
    </fieldset>
</form>
