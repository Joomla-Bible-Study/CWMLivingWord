<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset>
        <field
            name="id"
            type="text"
            label="JGLOBAL_FIELD_ID_LABEL"
            class="readonly"
            readonly="true"
            size="10"
            default="0"
        />
        <field
            name="plan"
            type="text"
            label="COM_LIVINGWORD_PLAN_NAME"
            description="COM_LIVINGWORD_READING_PLAN_DESC"
            required="true"
            size="50"
            maxlength="50"
        />
        <field
            name="reading"
            type="text"
            label="COM_LIVINGWORD_READING"
            description="COM_LIVINGWORD_READING_DESC"
