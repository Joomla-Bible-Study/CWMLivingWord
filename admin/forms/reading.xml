            name="audio"
            type="text"
            label="COM_LIVINGWORD_READING_AUDIO"
            description="COM_LIVINGWORD_READING_AUDIO_DESC"
            size="50"
            maxlength="50"
        />
        <field
            name="figure"
            type="text"
            label="COM_LIVINGWORD_READING_FIGURE"
            description="COM_LIVINGWORD_READING_FIGURE_DESC"
            size="80"
            maxlength="100"
        />
        <field
            name="descrip"
            type="textarea"
            label="COM_LIVINGWORD_READING_DESCRIPTION"
            description="COM_LIVINGWORD_READING_DESCRIPTION_DESC"
