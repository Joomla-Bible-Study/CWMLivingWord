<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset>
        <field
            name="id"
            type="hidden"
            default="0"
        />
        <field
            name="plan"
            type="sql"
            label="COM_LIVINGWORD_PLAN_NAME"
            description="COM_LIVINGWORD_READING_PLAN_DESC"
            required="true"
            sql_select="name"
            sql_value="name"
            sql_from="#__livingword_plans"
            sql_filter="name"
            sql_order="ordering ASC"
            key_field="name"
            value_field="name"
            header="COM_LIVINGWORD_SELECT_PLAN"
            query="SELECT name AS value, name AS text FROM #__livingword_plans WHERE published = 1 ORDER BY ordering"
        />
        <field
            name="reading"
            type="text"
            label="COM_LIVINGWORD_READING"
            description="COM_LIVINGWORD_READING_DESC"
            hint="COM_LIVINGWORD_READING_HINT"
            required="true"
            size="80"
            maxlength="255"
        />
        <field
            name="audio"
            type="text"
            label="COM_LIVINGWORD_READING_AUDIO"
            description="COM_LIVINGWORD_READING_AUDIO_DESC"
            size="50"
            maxlength="50"
        />
        <field
            name="descrip"
            type="textarea"
            label="COM_LIVINGWORD_READING_DESCRIPTION"
            description="COM_LIVINGWORD_READING_DESCRIPTION_DESC"
            rows="3"
            cols="60"
        />
        <field
            name="ordering"
            type="ordering"
            label="JFIELD_ORDERING_LABEL"
        />
    </fieldset>
</form>
