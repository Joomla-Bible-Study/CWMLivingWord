<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset addfieldprefix="CWM\Component\Livingword\Administrator\Field">
        <field
            name="id"
            type="text"
            label="JGLOBAL_FIELD_ID_LABEL"
            class="readonly"
            readonly="true"
            size="10"
            default="0"
        />
        <field
            name="name"
            type="text"
            label="COM_LIVINGWORD_LINK_NAME"
            description="COM_LIVINGWORD_LINK_NAME_DESC"
            required="true"
            size="60"
            maxlength="200"
        />
        <field
            name="url"
            type="url"
            label="COM_LIVINGWORD_LINK_URL"
            description="COM_LIVINGWORD_LINK_URL_DESC"
            required="true"
            size="60"
            maxlength="200"
        />
        <field
            name="category"
            type="text"
            label="COM_LIVINGWORD_LINK_CATEGORY"
            description="COM_LIVINGWORD_LINK_CATEGORY_DESC"
            size="40"
            maxlength="100"
        />
        <field
            name="target"
            type="list"
            label="COM_LIVINGWORD_LINK_TARGET"
            description="COM_LIVINGWORD_LINK_TARGET_DESC"
            default="2"
        >
            <option value="0">COM_LIVINGWORD_LINK_TARGET_SAME</option>
            <option value="2">COM_LIVINGWORD_LINK_TARGET_NEW</option>
        </field>
        <field
            name="published"
            type="list"
            label="JSTATUS"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field
            name="ordering"
            type="text"
            label="JFIELD_ORDERING_LABEL"
            size="6"
        />
    </fieldset>
</form>
