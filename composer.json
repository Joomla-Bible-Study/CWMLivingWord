{
  "name": "cwm/com-livingword",
  "type": "project",
  "description": "CWM LivingWord Bible Reading Plan Component for Joomla 5+",
  "keywords": [
    "bible",
    "joomla",
    "reading-plan",
    "livingword"
  ],
  "homepage": "https://github.com/Joomla-Bible-Study/CWMLivingWord",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "CWM Team",
      "email": "info@christianwebministries.org",
      "homepage": "https://www.christianwebministries.org",
      "role": "Lead Developer"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.3.0"
    },
    "vendor-dir": "libraries/vendor",
    "github-protocols": [
      "https"
    ],
    "allow-plugins": {}
  },
  "support": {
    "issues": "https://www.christianwebministries.org/issues",
    "forum": "https://www.christianwebministries.org/forum",
    "docs": "https://www.christianwebministries.org/docs"
  },
  "autoload": {
    "psr-4": {
      "CWM\\Component\\Livingword\\Administrator\\": "admin/src/",
      "CWM\\Component\\Livingword\\Site\\": "site/src/",
      "CWM\\Library\\Scripture\\": "libraries/cwmscripture_src/lib_cwmscripture/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CWM\\Component\\Livingword\\Tests\\": "tests/unit/"
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/Joomla-Bible-Study/cwm-build-tools"
    }
  ],
  "require": {
    "php": "^8.3.0",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-simplexml": "*",
    "ext-pdo": "*",
    "ext-zip": "*"
  },
  "require-dev": {
    "cwm/build-tools": "^0.4@alpha",
    "phpunit/phpunit": "^12.5",
    "friendsofphp/php-cs-fixer": "^3.0",
    "roave/security-advisories": "dev-latest",
    "joomla/database": "^4.0",
    "joomla/registry": "^4.0",
    "joomla/di": "^4.0",
    "joomla/event": "^4.0",
    "joomla/input": "^4.0",
    "joomla/filter": "^4.0",
    "joomla/filesystem": "^4.0",
    "joomla/uri": "^4.0",
    "joomla/application": "^4.0",
    "joomla/string": "^4.0"
  },
  "scripts": {
    "test":               "phpunit",
    "test:unit":          "phpunit --testsuite 'LivingWord Unit Tests'",
    "test:integration":   "phpunit --testsuite 'LivingWord Integration Tests'",
    "lint:syntax":        "find admin/src site/src mod_livingword plg_task_livingword -type f -name '*.php' -print0 2>/dev/null | xargs -0 -n 1 -P 8 php -l > /dev/null",
    "lint":               "php-cs-fixer fix --dry-run --diff",
    "lint:fix":           "php-cs-fixer fix",
    "check":              ["@lint:syntax", "@lint", "@test"],
    "setup":              "cwm-setup",
    "joomla-install":     "cwm-joomla-install",
    "joomla-latest":      "cwm-joomla-latest",
    "link":               "cwm-link",
    "link-check":         "cwm-link-check",
    "verify":             "cwm-verify",
    "clean":              "cwm-clean",
    "build":              "php build/livingword_build.php build",
    "release":            "cwm-release",
    "bump-version":       "cwm-bump",
    "package":            "cwm-package",
    "ars-publish":        "cwm-ars-publish",
    "ars-list":           "cwm-ars-list",
    "ars-create-stream":  "cwm-ars-create-stream",
    "changelog":          "cwm-changelog",
    "sync-configs":       "cwm-sync-configs",
    "sync-languages":     "cwm-sync-languages",
    "post-install-cmd": [
      "@php -r \"if (!file_exists('build.properties')) { copy('build.dist.properties', 'build.properties'); echo 'Created build.properties from template. Run composer setup to configure.\\n'; }\""
    ]
  }
}
